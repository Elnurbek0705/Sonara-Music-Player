{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sonara",
  "version": "0.1.0",
  "identifier": "com.elnurbek.sonara",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
   "app": {
   "windows": [
      {
         "title": "Sonara",
         "width": 420,
         "height": 500,
         "minWidth": 420,
         "minHeight": 500,
         "decorations": false,
         "resizable": true,
         "fullscreen": false,
         "transparent": true
      }
   ],
   "security": {
      "csp": null,
      "assetProtocol": {
         "enable": true,
         "scope": ["**"]
      }
   }
   },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
