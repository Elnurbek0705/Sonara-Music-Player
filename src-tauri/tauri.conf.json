{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sonara",
  "version": "0.2.0",
  "identifier": "com.elnurbek.sonara",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sonara",
        "width": 420,
        "height": 500,
        "minWidth": 420,
        "minHeight": 500,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "closable": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: asset: http://asset.localhost; media-src 'self' https: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' https: ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": [
      "binaries/yt-dlp"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2NjkyOEFFMUVFQkYwNTUKUldSVjhPc2VyaWhwRmlRYXZmRVJxWnpXc3FaWTB5NXNJc1VDc1cyeUJSQitUOTdkQ3N4TGJYYjEK",
      "endpoints": [
        "https://github.com/Elnurbek0705/Sonara-Music-Player/releases/latest/download/latest.json"
      ]
    }
  }
}